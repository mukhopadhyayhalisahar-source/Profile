// src/components/medical-features/NeurologicalScreening/processors/AudioProcessor.ts
export class AudioProcessor {
  static async analyzeVoiceJitter(audioBuffer: AudioBuffer) {
    const raw = audioBuffer.getChannelData(0);
    const f0 = this.estimateF0(raw); // Fundamental frequency

    // Jitter: frame-to-frame F0 variation
    const frames = this.extractFrames(raw, 512);
    const f0Values = frames.map(f => this.estimateF0(f));
    const jitter = this.calculateJitter(f0Values);

    return { f0, jitter, shimmer: this.calculateShimmer(frames) };
  }

  private static estimateF0(frame: Float32Array): number {
    // Autocorrelation-based F0 estimation (simplified)
    let maxCorr = 0, maxLag = 0;
    for (let lag = 40; lag < 400; lag++) {
      let corr = 0;
      for (let i = 0; i < frame.length - lag; i++) {
        corr += frame[i] * frame[i + lag];
      }
      if (corr > maxCorr) { maxCorr = corr; maxLag = lag; }
    }
    return 16000 / maxLag; // Sample rate / lag
  }

  private static calculateJitter(f0Values: number[]) {
    // Mean absolute difference in fundamental frequency
    let sumDiff = 0;
    for (let i = 1; i < f0Values.length; i++) {
      sumDiff += Math.abs(f0Values[i] - f0Values[i - 1]);
    }
    return (sumDiff / (f0Values.length - 1)) / 100; // Normalize
  }

  private static calculateShimmer(frames: Float32Array[]) {
    // Mean absolute difference in RMS amplitude
    const rms = frames.map(f => Math.sqrt(f.reduce((a, b) => a + b ** 2, 0) / f.length));
    let sumDiff = 0;
    for (let i = 1; i < rms.length; i++) {
      sumDiff += Math.abs(rms[i] - rms[i - 1]);
    }
    return (sumDiff / (rms.length - 1)) / 0.03; // Normalize
  }

  private static extractFrames(data: Float32Array, frameSize: number) {
    const frames = [];
    for (let i = 0; i < data.length - frameSize; i += frameSize / 2) {
      frames.push(data.slice(i, i + frameSize));
    }
    return frames;
  }
}
