// src/components/medical-features/NeurologicalScreening/hooks/useConfidenceMetrics.ts
export const useConfidenceMetrics = (landmarks: any, fps: number, audioQuality: number) => {
  const computeConfidence = () => {
    let confidence = 100;

    // FPS penalty
    if (fps < 20) confidence -= 30;
    else if (fps < 30) confidence -= 15;

    // Landmark detection penalty
    if (!landmarks || landmarks.faceLandmarks.length === 0) confidence -= 50;

    // Movement penalty (if face bounding box changes too much)
    if (landmarks && hasExcessiveMotion(landmarks)) confidence -= 20;

    // Audio quality penalty
    if (audioQuality < 0.5) confidence -= 25;

    return Math.max(0, Math.min(100, confidence));
  };

  return { confidence: computeConfidence() };
};
