import { useEffect, useState } from 'react';

export const useFacialSymmetry = (landmarks: any) => {
  const [symmetryScore, setSymmetryScore] = useState(100);
  const [asymmetricRegions, setAsymmetricRegions] = useState<string[]>([]);

  useEffect(() => {
    if (!landmarks || !landmarks.faceLandmarks || landmarks.faceLandmarks.length === 0) return;

    const face = landmarks.faceLandmarks[0];

    // Paired landmarks (left, right)
    const pairs = [
      { name: 'mouth', left: 61, right: 291 },
      { name: 'eye', left: 33, right: 263 },
      { name: 'eyebrow', left: 70, right: 300 },
      { name: 'cheek', left: 226, right: 446 },
    ];

    let totalAsymmetry = 0;
    const regions: string[] = [];
    const threshold = 0.05; // 5% asymmetry threshold

    pairs.forEach(pair => {
      const left = face[pair.left];
      const right = face[pair.right];

      const leftDist = Math.sqrt(left.x ** 2 + left.y ** 2);
      const rightDist = Math.sqrt(right.x ** 2 + right.y ** 2);

      const asymmetry = Math.abs(leftDist - rightDist) / ((leftDist + rightDist) / 2);

      totalAsymmetry += asymmetry;
      if (asymmetry > threshold) regions.push(pair.name);
    });

    const avgAsymmetry = totalAsymmetry / pairs.length;
    const score = Math.max(0, 100 - avgAsymmetry * 1000); // Normalize to 0–100

    setSymmetryScore(score);
    setAsymmetricRegions(regions);
  }, [landmarks]);

