#### **2.1 Blink Rate & Duration**
```typescript
// src/components/medical-features/NeurologicalScreening/hooks/useBlinkDetection.ts
import { useEffect, useRef, useState } from 'react';

const EAR_THRESHOLD = 0.2; // Eye Aspect Ratio threshold

export const useBlinkDetection = (landmarks: any) => {
  const [blinkRate, setBlinkRate] = useState(0);
  const [blinkDuration, setBlinkDuration] = useState(0);
  const blinkCountRef = useRef(0);
  const blinkStartRef = useRef<number | null>(null);
  const lastBlinkRef = useRef(0);
  const durationHistoryRef = useRef<number[]>([]);

  useEffect(() => {
    if (!landmarks || !landmarks.faceLandmarks || landmarks.faceLandmarks.length === 0) return;

    const face = landmarks.faceLandmarks[0];
    
    // Eye landmarks (MediaPipe indices)
    const leftEye = [33, 133, 160, 158, 133, 153].map(i => face[i]);
    const rightEye = [362, 263, 387, 385, 263, 373].map(i => face[i]);

    const leftEAR = calculateEAR(leftEye);
    const rightEAR = calculateEAR(rightEye);
    const avgEAR = (leftEAR + rightEAR) / 2;

    if (avgEAR < EAR_THRESHOLD && !blinkStartRef.current) {
      // Blink started
      blinkStartRef.current = performance.now();
    } else if (avgEAR >= EAR_THRESHOLD && blinkStartRef.current) {
      // Blink ended
      const duration = performance.now() - blinkStartRef.current;
      blinkCountRef.current++;
      durationHistoryRef.current.push(duration);
      if (durationHistoryRef.current.length > 100) durationHistoryRef.current.shift();
      setBlinkDuration(duration);
      blinkStartRef.current = null;
    }

    // Calculate blinks per minute (every 60 seconds)
    const now = performance.now();
    if (now - lastBlinkRef.current > 60000) {
      setBlinkRate(blinkCountRef.current);
      blinkCountRef.current = 0;
      lastBlinkRef.current = now;
    }
  }, [landmarks]);

  const calculateEAR = (eyeLandmarks: any[]) => {
    // Euclidean distances
    const dist = (p1: any, p2: any) => Math.sqrt((p1.x - p2.x) ** 2 + (p1.y - p2.y) ** 2);
    const vertical1 = dist(eyeLandmarks[1], eyeLandmarks[5]);
    const vertical2 = dist(eyeLandmarks[2], eyeLandmarks[4]);
    const horizontal = dist(eyeLandmarks[0], eyeLandmarks[3]);
    return (vertical1 + vertical2) / (2 * horizontal);
  };

  return { blinkRate, blinkDuration, avgDuration: durationHistoryRef.current.length > 0 ? durationHistoryRef.current.reduce((a, b) => a + b) / durationHistoryRef.current.length : 0 };
};
