```typescript
// src/components/medical-features/NeurologicalScreening/hooks/useTremorAnalysis.ts
import { useEffect, useRef, useState } from 'react';
import FFT from 'fft.js';

export const useTremorAnalysis = (landmarks: any) => {
  const [tremorFrequency, setTremorFrequency] = useState(0);
  const [tremorAmplitude, setTremorAmplitude] = useState(0);
  const positionHistoryRef = useRef<Array<{ x: number; y: number }>>([]);

  useEffect(() => {
    if (!landmarks || !landmarks.faceLandmarks || landmarks.faceLandmarks.length === 0) return;

    const face = landmarks.faceLandmarks[0];
    const nosePos = face[1]; // Nose landmark

    positionHistoryRef.current.push({ x: nosePos.x, y: nosePos.y });

    // Keep only last 60 samples (2 seconds @ 30 FPS)
    if (positionHistoryRef.current.length > 60) {
      positionHistoryRef.current.shift();
    }

    // Need at least 32 samples for meaningful FFT
    if (positionHistoryRef.current.length < 32) return;

    // Compute FFT on X-axis displacement
    const xPositions = positionHistoryRef.current.map(p => p.x);
    const detrended = detrend(xPositions);

    const fft = new FFT(64); // Pad to 64 for power of 2
    const padded = [...detrended, ...Array(64 - detrended.length).fill(0)];
    const spectrum = fft.createComplexArray();
    fft.transform(spectrum, padded);

    // Find dominant frequency
    const magnitudes = [];
    for (let i = 0; i < spectrum.length; i += 2) {
      magnitudes.push(Math.sqrt(spectrum[i] ** 2 + spectrum[i + 1] ** 2));
    }

    const peakIdx = magnitudes.indexOf(Math.max(...magnitudes));
    const freqHz = (peakIdx * 30) / 64; // FPS / FFT size

    const amplitude = Math.sqrt(detrended.reduce((a, b) => a + b ** 2, 0) / detrended.length);

    setTremorFrequency(freqHz);
    setTremorAmplitude(amplitude);
  }, [landmarks]);

  const detrend = (data: number[]) => {
    const n = data.length;
    const mean = data.reduce((a, b) => a + b) / n;
    return data.map(x => x - mean);
  };

  return { tremorFrequency, tremorAmplitude };
};
